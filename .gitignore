# =========================
# 🔒 ENV FILES (IMPORTANT)
# =========================
.env
.env.*
!.env.example

# =========================
# 📦 NODE (Frontend + Backend)
# =========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================
# ⚛️ NEXT.JS (Frontend)
# =========================
frontend/.next/
frontend/out/
frontend/node_modules/

# =========================
# ⚡ NODE BACKEND
# =========================
backend/node_modules/
backend/dist/
backend/build/

# =========================
# 🐍 PYTHON (AI - FastAPI)
# =========================
ai/venv/
ai/__pycache__/
ai/*.pyc
ai/*.pyo

# =========================
# 🧠 MODEL FILES (VERY IMPORTANT)
# =========================
ai/models/*.pth
ai/models/*.pt
ai/models/*.onnx

# =========================
# 📊 DATASETS (if any)
# =========================
ai/data/
*.npy

# =========================
# 🧪 LOGS & TEMP
# =========================
logs/
*.log
pids/
*.pid

# =========================
# 📈 COVERAGE
# =========================
coverage/
.nyc_output/

# =========================
# 🖥️ OS FILES
# =========================
.DS_Store
Thumbs.db

# =========================
# 🧰 EDITOR
# =========================
.vscode/
.idea/

# =========================
# ⚙️ BUILD FILES
# =========================
dist/
build/
.cache/

# =========================
